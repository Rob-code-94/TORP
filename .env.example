# Copy this file to `.env.local` and fill in values.
# Get remaining values from Firebase: Project settings → Your apps → Web app → `firebaseConfig`.
# VITE_FIREBASE_PROJECT_ID must match the GCP/Firebase project where your Firestore data lives (same project as the console).
# Firebase Authentication → Users does not show tenantId as a column; tenant scope is JWT custom claims (see docs/crew-directory-troubleshooting.md).
# Project ID below defaults to canonical TORP production; override only if using a separate dev GCP project.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=torp-hub
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Public marketing Firestore subtree (showcase + portfolio). Defaults to torp-default when unset.
# VITE_MARKETING_TENANT_ID=torp-default
# VITE_FIREBASE_FUNCTIONS_REGION=us-central1
# VITE_FIREBASE_USE_EMULATOR=true
# VITE_DEMO_BANNER=true
#
# HQ + seeds align with Cloud Run / docs/firestore-hq-bootstrap.md (canonical project: torp-hub).