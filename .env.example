# Copy this file to `.env.local` and fill in values.
# Get values from Firebase: Project settings → Your apps → Web app → `firebaseConfig`.
# Do NOT put real keys in this file — it is safe to commit. Use `.env.local` for secrets.
# Project ID (e.g. torp-hub) is not the same as the display name in the console.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Public marketing Firestore subtree (showcase + portfolio). Defaults to torp-default when unset.
# VITE_MARKETING_TENANT_ID=torp-default
# VITE_FIREBASE_FUNCTIONS_REGION=us-central1
# VITE_FIREBASE_USE_EMULATOR=true
# VITE_DEMO_BANNER=true
