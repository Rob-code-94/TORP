# Copy to `.env.local` and fill with values from Firebase: Project settings → Your apps → Web app
# The Project ID here MUST match Firebase → Project settings → Project ID (e.g. torp-hub).
# Display name in the console (e.g. "TORPv1") is not the same as Project ID.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_FUNCTIONS_REGION=us-central1
# VITE_FIREBASE_USE_EMULATOR=true
# VITE_DEMO_BANNER=true
