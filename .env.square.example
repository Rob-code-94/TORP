# Copy to `.env.square.local` (git-ignored). Never commit real tokens.
# Sync to Secret Manager: ./scripts/sync-square-secrets-from-env.sh
# Apply to Cloud Run: ./scripts/apply-square-cloud-run-env.sh

# Production (TORP LLC Square app — not IW Capital)
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=production
SQUARE_WEBHOOK_SIGNATURE_KEY=
# Must match Square Developer → Webhooks → Production notification URL exactly.
# Default uses canonical Cloud Run host (see docs/square-setup.md).
SQUARE_WEBHOOK_NOTIFICATION_URL=https://torp-cinematic-production-management-483040408359.us-west1.run.app/api/webhooks/square

# Optional: override only if gcloud status.url differs from the default above
# TORP_CANONICAL_CLOUD_RUN_URL=https://torp-cinematic-production-management-483040408359.us-west1.run.app

# Sandbox (optional local testing — swap token/location/key; set SQUARE_ENVIRONMENT=sandbox)
# SQUARE_ACCESS_TOKEN_SANDBOX=
# SQUARE_LOCATION_ID_SANDBOX=
